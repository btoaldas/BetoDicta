# BetoDicta — variables de entorno (EJEMPLO)
# Copia este archivo a ~/.betodicta/.env y pon tus claves reales:
#   mkdir -p ~/.betodicta && cp .env.example ~/.betodicta/.env
# JAMÁS subas tu .env real a git — el .gitignore lo bloquea por diseño.

# ── OBLIGATORIA: transcripción de voz a texto (ElevenLabs Scribe) ──
# Clave gratis en https://elevenlabs.io (perfil → API Keys)
ELEVENLABS_API_KEY=tu_clave_de_elevenlabs_aqui

# ── OPCIONAL: post-proceso con IA (limpia muletillas, puntuación, glosario) ──
# Solo si activas "post_proceso": true en config.json
# Clave gratis en https://console.groq.com (API Keys) — usa llama-3.3-70b
GROQ_API_KEY=tu_clave_de_groq_aqui
