# BetoDicta — variables de entorno (REFERENCIA, opcional)
#
# NO necesitas este archivo para usar BetoDicta. El asistente de configuración
# (o Ajustes → Modelos / "Conectar más IAs") guarda tus claves solo, en
# ~/.betodicta/.env con permisos 0600. Esta plantilla es solo para DESARROLLO
# o si prefieres poner las claves a mano.
#
# Cargar claves a mano:  mkdir -p ~/.betodicta && cp .env.example ~/.betodicta/.env
# JAMÁS subas tu .env real a git — el .gitignore lo bloquea por diseño.
#
# NINGUNA clave es obligatoria: hay motores LOCALES gratis (Whisper, Voxtral,
# Nemotron, Canary) que corren sin internet ni claves. Pon solo las de los
# servicios de nube que quieras usar. Convención: <PROVEEDOR>_API_KEY.
# En la app, cada proveedor tiene un botón "Conseguir clave" a su página oficial.

# ── Transcripción de voz (elige los que quieras; ninguno obligatorio) ──
# ELEVENLABS_API_KEY=        # calidad top, texto en vivo (de pago)
# GROQ_API_KEY=              # Whisper GRATIS 2000/día (sin tarjeta)
# HF_API_KEY=                # Hugging Face Whisper (capa gratis)
# OPENAI_API_KEY=            # Whisper / gpt-4o-transcribe
# MISTRAL_API_KEY=           # Voxtral
# FIREWORKS_API_KEY=         # Whisper
# DEEPGRAM_API_KEY=          # Nova (soporta EN VIVO)
# SONIOX_API_KEY=            # premium, español latino (EN VIVO)
# ASSEMBLYAI_API_KEY=        # Universal (EN VIVO)
# GLADIA_API_KEY=            # 10 h/mes gratis (EN VIVO)
# SPEECHMATICS_API_KEY=      # 480 min/mes gratis (EN VIVO)
# CLOUDFLARE_API_KEY=        # Workers AI Whisper (necesita también Account ID)
# AZURE_SPEECH_KEY=          # Azure AI Speech, es-EC (necesita también región)

# ── Pulido / traducción con IA (opcional) ──
# GROQ_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, MISTRAL_API_KEY,
# OPENROUTER_API_KEY, DEEPSEEK_API_KEY, XAI_API_KEY, CEREBRAS_API_KEY, GITHUB_MODELS_KEY,
# NVIDIA_API_KEY, TOGETHER_API_KEY, NOVITA_API_KEY, ZAI_CHAT_API_KEY, SILICONFLOW_API_KEY
